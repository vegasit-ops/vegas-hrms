# VEGAS IT GLOBAL - HRMS Environment Variables
# Copy this file to .env and fill in the values
# Usage: cp .env.example .env

# Docker image settings
CUSTOM_IMAGE=vegas-hrms
CUSTOM_TAG=v15
PULL_POLICY=never

# MariaDB root password (used during site creation)
DB_PASSWORD=changeme_secure_password

# HTTP port (Docker frontend listens here, Nginx proxies to it)
HTTP_PUBLISH_PORT=8080

# Frappe frontend settings
FRAPPE_SITE_NAME_HEADER=hrms.cloudagents.uk
UPSTREAM_REAL_IP_ADDRESS=127.0.0.1
UPSTREAM_REAL_IP_HEADER=X-Forwarded-For
UPSTREAM_REAL_IP_RECURSIVE=off
PROXY_READ_TIMEOUT=120s
CLIENT_MAX_BODY_SIZE=50m

# Backup retention (days)
BACKUP_RETENTION_DAYS=7
